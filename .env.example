# ════════════════════════════════════════════════════════════════
# MEEET World — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets.
# ════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────

# Supabase project URL
SUPABASE_URL=

# Supabase anonymous/publishable key (safe to expose in frontend)
SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key (server-side only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase anon key (alias used by some edge functions)
SUPABASE_ANON_KEY=

# Supabase database connection URL (used internally)
SUPABASE_DB_URL=

# Supabase project ID (used in frontend via VITE_ prefix)
VITE_SUPABASE_PROJECT_ID=

# Frontend Supabase URL
VITE_SUPABASE_URL=

# Frontend Supabase publishable key
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Telegram ──────────────────────────────────────────────────

# Telegram bot token from @BotFather (for world-pulse and automation notifications)
TELEGRAM_BOT_TOKEN=

# Telegram chat/channel ID for notifications
TELEGRAM_CHAT_ID=

# Admin Telegram chat ID for admin-level alerts
ADMIN_CHAT_ID=

# Telegram connector API key (for gateway-based bot integrations)
TELEGRAM_API_KEY=

# ── AI / LLM ─────────────────────────────────────────────────

# OpenAI API key (used by content generation edge functions)
OPENAI_API_KEY=

# Lovable AI Gateway key (managed automatically by Lovable Cloud)
LOVABLE_API_KEY=

# OpenClaw gateway URL and token (external AI gateway)
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=

# ── Solana / Crypto ───────────────────────────────────────────

# Solana RPC endpoint URL
SOLANA_RPC_URL=

# Trading wallet private key (base58 or JSON array format)
TRADING_WALLET_KEY=

# Treasury wallet private key (base58 or JSON array format)
TREASURY_WALLET_PRIVATE_KEY=

# Jupiter aggregator API key
JUPITER_API_KEY=

# ── Admin / Auth ──────────────────────────────────────────────

# President API key for admin edge functions
PRESIDENT_API_KEY=

# President owner user ID (UUID)
PRESIDENT_OWNER_USER_ID=

# Internal service secret for inter-function auth
INTERNAL_SERVICE_SECRET=

# ── Integrations ──────────────────────────────────────────────

# Spix API key (Bearer token for Spix communications)
SPIX_API_KEY=

# GitHub personal access token
GITHUB_TOKEN=

# Stripe secret key (payments)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=
